# Generated by Cargo
# will have compiled files and executables
/target/

# ignore .env files which may contain sensitive information
.env

# Remove Cargo.lock from gitignore if creating a library, leave it for binaries
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# IDE files
.vscode/
.idea/

# Temporary files
*.tmp
*.temp

# Build artifacts
*.rmeta
*.rlib
*.dSYM/

# Ignore generated test outputs
**/target/**
